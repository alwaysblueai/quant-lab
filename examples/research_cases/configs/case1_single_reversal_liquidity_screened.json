{
  "data": {
    "prices_path": "../data/prices_case_panel.csv",
    "asset_metadata_path": "../data/asset_metadata_case_panel.csv",
    "market_state_path": "../data/market_state_case_panel.csv",
    "neutralization_exposures_path": "../data/neutralization_exposures_case_panel.csv"
  },
  "factor": {
    "name": "reversal",
    "params": {
      "window": 5
    }
  },
  "spec": {
    "experiment_name": "case1_single_reversal_liquidity_screened",
    "horizon": 5,
    "n_quantiles": 5,
    "label_method": "rankpct",
    "validation_mode": "purged_kfold",
    "purged_n_splits": 5,
    "purged_embargo_periods": 1,
    "universe_rules": {
      "min_listing_age_days": 120,
      "min_adv": 300000.0,
      "adv_window": 20
    },
    "preprocess": {
      "apply_winsorize": true,
      "winsorize_lower": 0.02,
      "winsorize_upper": 0.98,
      "apply_zscore": true,
      "apply_rank": false,
      "min_group_size": 10,
      "min_coverage": 0.7
    },
    "neutralization": {
      "size_col": "size_exposure",
      "industry_col": "industry",
      "beta_col": "beta_exposure",
      "min_obs": 20,
      "ridge": 1e-08
    },
    "hypothesis": "Liquidity-screened short-term reversal should retain cross-sectional mean reversion after neutralization.",
    "research_question": "Does a 5-day reversal signal remain statistically useful under PIT tradability constraints and purged validation?",
    "factor_spec": "reversal_5d with min ADV screen and size/industry/beta residualization",
    "dataset_id": "research_case_panel_v1",
    "trial_id": "case1-trial-001",
    "trial_count": 2,
    "assumptions": [
      "Cross-sectional equity research setting",
      "No execution simulation; strict backtest delegated externally"
    ],
    "append_trial_log": true,
    "update_registry": false,
    "export_handoff": true,
    "handoff_include_label_snapshot": true
  }
}
